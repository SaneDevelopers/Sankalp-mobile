{
  "expo": {
    "name": "Sankalp",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/sankalp_logo.jpg",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/sankalp_logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#FAF3E8"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sankalp.mobile"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/sankalp_logo.jpg",
        "backgroundColor": "#FAF3E8"
      }
    },
    "web": {
      "favicon": "./assets/images/sankalp_logo.jpg"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "@react-native-google-signin/google-signin"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
