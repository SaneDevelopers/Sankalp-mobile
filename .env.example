# Copy this file to .env and fill in real values
# .env is git-ignored so real secrets stay local

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/postgres
JWT_SECRET=sankalp-dev-secret-key-123456

# Admin Console credentials
# EXPO_PUBLIC_ prefix bakes these into the Expo JS bundle at build time
EXPO_PUBLIC_ADMIN_EMAIL=admin@yourdomain.com
EXPO_PUBLIC_ADMIN_PASSWORD=your-strong-password-here
